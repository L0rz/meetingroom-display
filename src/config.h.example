// ══════════════════════════════════════════════════════════════════
//  Meetingroom E-Paper Display — Konfiguration
//  Alle einstellbaren Parameter an einer Stelle.
// ══════════════════════════════════════════════════════════════════

// ── WiFi ─────────────────────────────────────────────────────────
#define WIFI_SSID          "DeepSpaceNetwork-iot"
#define WIFI_PASSWORD      "microbots"

// ── MQTT Broker ──────────────────────────────────────────────────
